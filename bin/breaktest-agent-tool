PRG="$0"

while [ -h "$PRG" ]; do
  ls=`ls -ld "$PRG"`
  link=`expr "$ls" : '.*-> \(.*\)$'`
  if expr "$link" : '/.*' > /dev/null; then
    PRG="$link"
  else
    PRG=`dirname "$PRG"`/"$link"
  fi
done

PRGDIR=`dirname "$PRG"`

# BREAKTEST_HOME takes precedence over the legacy JMETER_HOME name
[ -n "$BREAKTEST_HOME" ] && JMETER_HOME="$BREAKTEST_HOME"
[ -z "$JMETER_HOME" ] && JMETER_HOME=`cd "$PRGDIR/.." >/dev/null; pwd`

if [ -r "${JMETER_HOME}/bin/setenv.sh" ]; then
  . "${JMETER_HOME}/bin/setenv.sh"
fi

if [ -z "$JAVA_HOME" -a -z "$JRE_HOME" ]; then
  if [ "`uname`" = "Darwin" ] && [ -x '/usr/libexec/java_home' ] ; then
    export JAVA_HOME=`/usr/libexec/java_home`
  else
    JAVA_PATH=`which java 2>/dev/null`
    if [ "x$JAVA_PATH" != "x" ]; then
      JAVA_PATH=`dirname "$JAVA_PATH" 2>/dev/null`
      JRE_HOME=`dirname "$JAVA_PATH" 2>/dev/null`
    fi
  fi
fi

if [ -z "$JRE_HOME" ]; then
  JRE_HOME="$JAVA_HOME"
fi
if [ -z "$JAVA_HOME" ]; then
  JAVA_HOME="$JRE_HOME"
fi
if [ -z "$JAVA_HOME" ]; then
  echo "Neither the JAVA_HOME nor the JRE_HOME environment variable is defined" >&2
  exit 1
fi

JAVA_OPTS="--add-opens=java.base/java.lang=ALL-UNNAMED --add-opens=java.base/java.lang.invoke=ALL-UNNAMED --add-opens=java.base/java.lang.reflect=ALL-UNNAMED --add-opens=java.base/java.util=ALL-UNNAMED --add-opens=java.base/java.text=ALL-UNNAMED"
: "${HEAP:="-Xms256m -Xmx1g -XX:MaxMetaspaceSize=256m"}"

CLASSPATH="${JMETER_HOME}/bin/ApacheJMeter.jar:${JMETER_HOME}/lib/*:${JMETER_HOME}/lib/ext/*:${JMETER_HOME}/lib/junit/*"

exec "$JAVA_HOME/bin/java" \
  $JAVA_OPTS \
  $HEAP \
  $JVM_ARGS \
  -Djava.awt.headless=true \
  -Djmeter.home="${JMETER_HOME}" \
  -Dlog4j.configurationFile="${JMETER_HOME}/bin/log4j2.xml" \
  -Djmeter.logfile="${JMETER_HOME}/bin/breaktest-agent-tool.log" \
  -cp "$CLASSPATH" \
  org.apache.jmeter.ai.mcp.BreakTestAgentToolCli \
  "$@"
