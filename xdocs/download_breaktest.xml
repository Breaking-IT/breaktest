<!DOCTYPE document
[
<!ENTITY release '2026.07.07'>
<!ENTITY hellip   "&#x02026;" >
]>

<document>
<properties>
    <title>Download BreakTest</title>
</properties>
<body>
    <section name="Download BreakTest">
      <p>
        BreakTest releases are published on GitHub. Download the binary archive
        for your platform preference and verify it with the matching SHA-512
        checksum.
      </p>
      <p>
        BreakTest requires Java 21 or later. It is a forked continuation of
        Apache JMeter and remains compatible with existing JMeter JMX test plans
        where practical.
      </p>
      <p>
        <a href="https://github.com/Breaking-IT/breaktest/releases/latest">Open the latest GitHub release</a>
      </p>
    </section>
    <section name="BreakTest &release; (Requires Java 21+)">
      <subsection name="Binaries" anchor="binaries">
        <table>
          <tr>
              <th>Archive</th>
              <th>Checksum</th>
          </tr>
          <tr>
              <td><a href="https://github.com/Breaking-IT/breaktest/releases/download/rel/v&release;/breaktest-&release;.tgz">breaktest-&release;.tgz</a></td>
              <td><a href="https://github.com/Breaking-IT/breaktest/releases/download/rel/v&release;/breaktest-&release;.tgz.sha512">sha512</a></td>
          </tr>
          <tr>
              <td><a href="https://github.com/Breaking-IT/breaktest/releases/download/rel/v&release;/breaktest-&release;.zip">breaktest-&release;.zip</a></td>
              <td><a href="https://github.com/Breaking-IT/breaktest/releases/download/rel/v&release;/breaktest-&release;.zip.sha512">sha512</a></td>
          </tr>
        </table>
      </subsection>
      <subsection name="Source" anchor="source">
        <table>
          <tr>
              <th>Archive</th>
              <th>Checksum</th>
          </tr>
          <tr>
              <td><a href="https://github.com/Breaking-IT/breaktest/releases/download/rel/v&release;/breaktest-&release;_src.tgz">breaktest-&release;_src.tgz</a></td>
              <td><a href="https://github.com/Breaking-IT/breaktest/releases/download/rel/v&release;/breaktest-&release;_src.tgz.sha512">sha512</a></td>
          </tr>
          <tr>
              <td><a href="https://github.com/Breaking-IT/breaktest/releases/download/rel/v&release;/breaktest-&release;_src.zip">breaktest-&release;_src.zip</a></td>
              <td><a href="https://github.com/Breaking-IT/breaktest/releases/download/rel/v&release;/breaktest-&release;_src.zip.sha512">sha512</a></td>
          </tr>
        </table>
      </subsection>
    </section>
    <section name="Verification of downloads">
    <p>
    Download the matching <code>.sha512</code> file and compare it with your local
    archive before running BreakTest.
    </p>
    <source>
shasum -a 512 breaktest-&release;.tgz
cat breaktest-&release;.tgz.sha512
    </source>
    </section>
    <section name="Relationship to Apache JMeter">
      <p>
      BreakTest is independent from The Apache Software Foundation. It is not
      affiliated with, endorsed by, or sponsored by The Apache Software
      Foundation. Apache JMeter attribution is retained in the source tree,
      release notices, and documentation where it describes origin or
      compatibility.
      </p>
      <p>
      For upstream Apache JMeter releases, see the
      <a href="https://jmeter.apache.org/">Apache JMeter</a> site.
      </p>
    </section>
</body>
</document>
