{
  "manifest_version": 3,
  "name": "BreakTest Browser Recorder",
  "description": "Record a Firefox session as HAR with named BreakTest transactions.",
  "version": "0.5.0",
  "permissions": [
    "activeTab",
    "browserSettings",
    "storage",
    "tabs",
    "webRequest",
    "webRequestBlocking",
    "webRequestFilterResponse"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "incognito": "spanning",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Open BreakTest Recorder",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "sidebar_action": {
    "default_title": "BreakTest Recorder",
    "default_panel": "sidebar.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    },
    "open_at_install": false
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "browser-recorder@breaktest.io",
      "strict_min_version": "128.0"
    }
  }
}
